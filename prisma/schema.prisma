generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model VendorStore {
  id              String   @id @default(cuid())
  ownerName       String
  storeName       String
  email           String
  phone           String
  address         String
  country         String
  category        String
  note            String?
  ageCheck        String
  isTestStore     Boolean  @default(false)
  isPlatformStore Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendorAuth             Vendor?
  seller                 Seller?
  products               Product[]
  returnAddresses        VendorReturnAddress[]
  withdrawalContracts    WithdrawalContract[]
  withdrawalReturnGroups WithdrawalReturnGroup[]
  governanceCases        MarketplaceOperationalCase[]
}

model Product {
  id                              String    @id @default(cuid())
  name                            String
  description                     String?
  imageUrl                        String?
  category                        String?
  price                           Int
  costAmount                      Decimal?  @db.Decimal(12, 2)
  costCurrency                    String    @default("JPY")
  url                             String?
  vendorStoreId                   String
  approvalStatus                  String    @default("pending")
  shopifyProductId                String?
  shopifyVariantId                String?
  shopDomain                      String?
  calculatedPrice                 Int?
  usedFxRate                      Float?
  usedMargin                      Float?
  usedDutyRate                    Float?
  usedFee                         Json?
  roundingResult                  Json?
  calculatedAt                    DateTime?
  priceSyncStatus                 String    @default("calculated_not_applied")
  priceSyncError                  String?
  priceAppliedAt                  DateTime?
  lastPriceApplyAttemptAt         DateTime?
  priceFormulaVersion             String?
  priceSnapshotJson               Json?
  inventoryQuantity               Int?
  inventorySyncedAt               DateTime?
  inventorySyncError              String?
  shippingWeightGrams             Int?
  shippingLengthMm                Int?
  shippingWidthMm                 Int?
  shippingHeightMm                Int?
  internationalShippingMethod     String    @default("UNCONFIGURED")
  shippingWeightConfirmedAt       DateTime?
  shippingWeightSource            String    @default("UNSET")
  shopifyVariantCount             Int?
  shopifyWeightSyncStatus         String    @default("NOT_LINKED")
  shopifyWeightSyncedAt           DateTime?
  shopifyWeightSyncError          String?
  productEuStatus                 String    @default("DISABLED")
  euSaleRequested                 Boolean   @default(false)
  regulatorySelfCertificationJson Json?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  vendorStore       VendorStore                  @relation(fields: [vendorStoreId], references: [id])
  priceApplyLogs    ProductPriceApplyLog[]
  countryPolicy     ProductCountryPolicy?
  complianceProfile ProductComplianceProfile?
  governanceCases   MarketplaceOperationalCase[]

  @@unique([shopDomain, shopifyProductId])
  @@unique([shopDomain, shopifyVariantId])
  @@index([shopifyProductId])
  @@index([shopifyVariantId])
  @@index([internationalShippingMethod, approvalStatus])
  @@index([shopifyWeightSyncStatus, approvalStatus])
  @@index([productEuStatus, updatedAt])
}

model InternationalShippingCountryAvailability {
  id          String    @id @default(cuid())
  countryCode String
  service     String    @default("JAPAN_POST_AIR_PACKET")
  status      String    @default("UNKNOWN")
  sourceUrl   String?
  note        String?
  checkedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([countryCode, service])
  @@index([service, status, checkedAt])
  @@map("international_shipping_country_availabilities")
}

model ShopifyProductSyncIssue {
  id                    String    @id @default(cuid())
  shopDomain            String
  shopifyProductId      String
  productTitle          String?
  vendorLabel           String?
  status                String    @default("unresolved")
  reason                String
  candidateStoreIdsJson Json?
  payloadJson           Json
  resolvedVendorStoreId String?
  localProductId        String?
  lastAttemptAt         DateTime  @default(now())
  resolvedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([shopDomain, shopifyProductId])
  @@index([status, lastAttemptAt])
  @@index([resolvedVendorStoreId])
  @@map("shopify_product_sync_issues")
}

model ProductPriceApplyLog {
  id                  String   @id @default(cuid())
  productId           String?
  shopifyProductId    String?
  shopDomain          String?
  attemptedPrice      Int?
  priceFormulaVersion String?
  status              String
  errorSummary        String?
  priceSnapshotJson   Json?
  attemptedAt         DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId, attemptedAt])
  @@index([shopifyProductId, shopDomain, attemptedAt])
}

model Vendor {
  id              String   @id @default(cuid())
  vendorStoreId   String   @unique
  storeName       String
  handle          String   @unique
  managementEmail String
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendorStore   VendorStore          @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  seller        Seller?
  loginCodes    VendorLoginCode[]
  adminSessions VendorAdminSession[]
}

model Seller {
  id                         String    @id @default(cuid())
  vendorId                   String    @unique
  vendorStoreId              String    @unique
  status                     String    @default("pending")
  statusReason               String?
  sellerLegalRole            String    @default("MARKETPLACE_SELLER")
  sellerVerificationStatus   String    @default("NONE")
  euSellerStatus             String    @default("DISABLED")
  phoneVerifiedAt            DateTime?
  documentVerificationStatus String    @default("NONE")
  documentVerifiedAt         DateTime?
  documentVerifiedBy         String?
  verificationNameMatched    Boolean   @default(false)
  payoutNameMatched          Boolean   @default(false)
  verificationReviewNotes    String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  vendor                Vendor                       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorStore           VendorStore                  @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  stripeAccount         SellerStripeAccount?
  payoutRecipient       SellerPayoutRecipient?
  statusHistory         SellerStatusHistory[]
  verificationRecords   SellerVerificationRecord[]
  orders                Order[]
  ledgerEntries         LedgerEntry[]
  payoutRuns            PayoutRun[]
  salesCreditOffsets    SalesCreditOffset[]
  withdrawalContracts   WithdrawalContract[]
  complianceProfile     SellerComplianceProfile?
  agreementAcceptances  SellerAgreementAcceptance[]
  settlementControl     SellerSettlementControl?
  governanceCases       MarketplaceOperationalCase[] @relation("OperationalCaseSeller")
  responsibilityCases   MarketplaceOperationalCase[] @relation("OperationalCaseResponsibleSeller")
  settlementAdjustments SellerSettlementAdjustment[]

  @@index([status, createdAt])
  @@index([sellerVerificationStatus, updatedAt])
  @@index([euSellerStatus, updatedAt])
  @@map("sellers")
}

model MarketplaceOrder {
  id                    String    @id @default(cuid())
  shopDomain            String
  shopifyOrderId        String
  shopifyOrderName      String?
  shopifyOrderNumber    String?
  buyerEmail            String?
  buyerName             String?
  totalAmount           Int       @default(0)
  subtotalAmount        Int       @default(0)
  shippingAmount        Int       @default(0)
  discountAmount        Int       @default(0)
  taxAmount             Int       @default(0)
  currencyCode          String    @default("jpy")
  financialStatus       String?
  fulfillmentStatus     String?
  processedAt           DateTime?
  cancelledAt           DateTime?
  buyerTermsVersion     String?
  buyerTermsHash        String?
  buyerTermsUrl         String?
  buyerTermsLocale      String?
  buyerTermsPresentedAt DateTime?
  checkoutReference     String?
  metadataJson          Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  sellerOrders            SellerOrder[]
  shadowChecks            SellerOrderShadowCheck[]
  withdrawalRequests      WithdrawalRequest[]
  withdrawalLinePositions WithdrawalOrderLinePosition[]
  withdrawalContracts     WithdrawalContract[]
  governanceCases         MarketplaceOperationalCase[]

  @@unique([shopDomain, shopifyOrderId])
  @@index([shopifyOrderId])
  @@index([shopDomain, createdAt])
  @@map("marketplace_orders")
}

model MarketplaceCheckoutEvidence {
  id                     String    @id @default(cuid())
  checkoutReference      String    @unique
  shopDomain             String
  status                 String    @default("PREPARED")
  sellerAgreementVersion String?
  sellerAgreementHash    String?
  sellerAgreementUrl     String?
  buyerTermsVersion      String?
  buyerTermsHash         String?
  buyerTermsUrl          String?
  buyerTermsLocale       String?
  presentedAt            DateTime
  sellerSnapshotsJson    Json
  productSnapshotsJson   Json
  shopifyOrderId         String?
  orderCapturedAt        DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([shopDomain, createdAt])
  @@index([status, createdAt])
  @@index([shopifyOrderId])
  @@map("marketplace_checkout_evidence")
}

model SellerOrder {
  id                          String    @id @default(cuid())
  marketplaceOrderId          String
  shopifyOrderId              String
  shopifyOrderName            String?
  sellerId                    String
  vendorStoreId               String?
  sellerSubtotalAmount        Int       @default(0)
  sellerDiscountAmount        Int       @default(0)
  sellerRefundAmount          Int       @default(0)
  sellerNetAmount             Int       @default(0)
  sellerPayableAmount         Int       @default(0)
  shippingQuotedAmount        Int       @default(0)
  shippingChargedAmount       Int       @default(0)
  shippingAllocationMethod    String    @default("not_allocated")
  currencyCode                String    @default("jpy")
  paymentStatus               String    @default("paid")
  fulfillmentStatus           String    @default("unfulfilled")
  settlementStatus            String    @default("shadow")
  riskStatus                  String    @default("normal")
  governanceSnapshotVersion   String?
  legalSellerSnapshotJson     Json?
  sellerAgreementSnapshotJson Json?
  buyerTermsVersion           String?
  buyerTermsHash              String?
  buyerTermsUrl               String?
  buyerTermsLocale            String?
  buyerTermsPresentedAt       DateTime?
  checkoutReference           String?
  metadataJson                Json?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  marketplaceOrder         MarketplaceOrder             @relation(fields: [marketplaceOrderId], references: [id], onDelete: Cascade)
  lines                    SellerOrderLine[]
  shipments                SellerShipment[]
  withdrawalContracts      WithdrawalContract[]
  withdrawalReturnGroups   WithdrawalReturnGroup[]
  withdrawalRequestedLines WithdrawalRequestedLine[]
  governanceCases          MarketplaceOperationalCase[]

  @@unique([marketplaceOrderId, sellerId])
  @@index([sellerId, createdAt])
  @@index([vendorStoreId, createdAt])
  @@index([marketplaceOrderId])
  @@map("seller_orders")
}

model SellerOrderLine {
  id                      String   @id @default(cuid())
  sellerOrderId           String
  shopifyLineItemId       String
  shopifyProductId        String?
  shopifyVariantId        String?
  productId               String?
  title                   String?
  sku                     String?
  quantity                Int      @default(0)
  fulfilledQuantity       Int      @default(0)
  refundedQuantity        Int      @default(0)
  unitAmount              Int      @default(0)
  lineSubtotalAmount      Int      @default(0)
  discountAmount          Int      @default(0)
  taxAmount               Int      @default(0)
  netAmount               Int      @default(0)
  currencyCode            String   @default("jpy")
  legalSellerSnapshotJson Json?
  complianceSnapshotJson  Json?
  sellerAgreementVersion  String?
  metadataJson            Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  sellerOrder              SellerOrder               @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  shipmentLines            SellerShipmentLine[]
  withdrawalRequestedLines WithdrawalRequestedLine[]

  @@unique([sellerOrderId, shopifyLineItemId])
  @@index([shopifyLineItemId])
  @@index([productId])
  @@map("seller_order_lines")
}

model SellerShipment {
  id                   String    @id @default(cuid())
  sellerOrderId        String
  shopifyFulfillmentId String?
  trackingNumber       String?
  trackingCompany      String?
  trackingUrl          String?
  status               String    @default("registered")
  shippedAt            DateTime?
  metadataJson         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  sellerOrder SellerOrder          @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  lines       SellerShipmentLine[]

  @@index([sellerOrderId, createdAt])
  @@index([shopifyFulfillmentId])
  @@index([trackingNumber])
  @@map("seller_shipments")
}

model SellerShipmentLine {
  id                                String   @id @default(cuid())
  sellerShipmentId                  String
  sellerOrderLineId                 String
  shopifyLineItemId                 String?
  shopifyFulfillmentOrderId         String
  shopifyFulfillmentOrderLineItemId String
  quantity                          Int      @default(0)
  createdAt                         DateTime @default(now())

  sellerShipment  SellerShipment  @relation(fields: [sellerShipmentId], references: [id], onDelete: Cascade)
  sellerOrderLine SellerOrderLine @relation(fields: [sellerOrderLineId], references: [id], onDelete: Cascade)

  @@unique([sellerShipmentId, shopifyFulfillmentOrderLineItemId])
  @@index([sellerOrderLineId])
  @@index([shopifyLineItemId])
  @@index([shopifyFulfillmentOrderId])
  @@map("seller_shipment_lines")
}

model SellerOrderShadowCheck {
  id                          String   @id @default(cuid())
  marketplaceOrderId          String?
  shopDomain                  String
  shopifyOrderId              String
  shopifyOrderName            String?
  status                      String
  currencyCode                String   @default("jpy")
  legacyLedgerAmount          Int?
  sellerOrderCalculatedAmount Int?
  legacySellerIdsJson         Json?
  sellerOrderSellerIdsJson    Json?
  differencesJson             Json?
  errorMessage                String?
  checkedAt                   DateTime @default(now())
  createdAt                   DateTime @default(now())

  marketplaceOrder MarketplaceOrder? @relation(fields: [marketplaceOrderId], references: [id], onDelete: SetNull)

  @@index([status, checkedAt])
  @@index([shopifyOrderId])
  @@index([marketplaceOrderId])
  @@map("seller_order_shadow_checks")
}

model OperationalHeartbeat {
  key             String    @id
  lastStartedAt   DateTime?
  lastSucceededAt DateTime?
  lastFailedAt    DateTime?
  lastErrorCode   String?
  metadataJson    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("operational_heartbeats")
}

model SalesCreditOffset {
  id                String    @id @default(cuid())
  sellerId          String
  amount            Int
  currencyCode      String    @default("jpy")
  status            String    @default("authorized")
  checkoutReference String?
  idempotencyKey    String?   @unique
  expiresAt         DateTime?
  capturedAt        DateTime?
  releasedAt        DateTime?
  releaseReason     String?
  metadataJson      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, status, expiresAt])
  @@index([checkoutReference])
  @@map("sales_credit_offsets")
}

model SellerVerificationRecord {
  id                 String    @id @default(cuid())
  sellerId           String
  status             String
  verifiedAt         DateTime?
  verifiedBy         String?
  verificationMethod String?
  documentType       String?
  documentCountry    String?
  documentLast4      String?
  nameMatched        Boolean   @default(false)
  payoutNameMatched  Boolean   @default(false)
  phoneVerifiedAt    DateTime?
  rejectionReason    String?
  reviewNotes        String?
  createdAt          DateTime  @default(now())

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@index([status, createdAt])
  @@map("seller_verification_records")
}

model SellerStripeAccount {
  id                    String    @id @default(cuid())
  sellerId              String    @unique
  stripeAccountId       String    @unique
  countryCode           String?
  defaultCurrency       String?
  detailsSubmitted      Boolean   @default(false)
  chargesEnabled        Boolean   @default(false)
  payoutsEnabled        Boolean   @default(false)
  payoutSchedule        String    @default("manual")
  dashboardType         String    @default("none")
  onboardingCompletedAt DateTime?
  requirementsJson      Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders        Order[]
  ledgerEntries LedgerEntry[]
  payoutRuns    PayoutRun[]

  @@map("seller_stripe_accounts")
}

model SellerPayoutRecipient {
  id                   String    @id @default(cuid())
  sellerId             String    @unique
  provider             String    @default("wise")
  status               String    @default("pending")
  countryCode          String?
  currencyCode         String    @default("jpy")
  legalType            String?
  accountHolderName    String?
  wiseProfileId        String?
  wiseRecipientId      String?   @unique
  wiseRecipientHash    String?
  accountSummary       String?
  longAccountSummary   String?
  recipientPayloadJson Json?
  requirementsJson     Json?
  verificationJson     Json?
  lastSyncedAt         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  seller     Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  payoutRuns PayoutRun[]

  @@index([provider, status])
  @@index([wiseRecipientId])
  @@map("seller_payout_recipients")
}

model SellerStatusHistory {
  id         String   @id @default(cuid())
  sellerId   String
  fromStatus String?
  toStatus   String
  changedBy  String?
  reason     String?
  createdAt  DateTime @default(now())

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@map("seller_status_history")
}

model Order {
  id                    String    @id @default(cuid())
  sellerId              String
  sellerStripeAccountId String?
  stripeAccountId       String?
  status                String    @default("draft")
  currencyCode          String    @default("jpy")
  subtotalAmount        Int
  applicationFeeAmount  Int
  totalAmount           Int
  customerEmail         String
  customerFirstName     String?
  customerLastName      String?
  customerPhone         String?
  shippingAddressJson   Json?
  lineItemsJson         Json
  stripePaymentIntentId String?   @unique
  stripeChargeId        String?   @unique
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  seller              Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerStripeAccount SellerStripeAccount? @relation(fields: [sellerStripeAccountId], references: [id], onDelete: SetNull)
  ledgerEntries       LedgerEntry[]

  @@index([sellerId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model StripeEvent {
  id               String    @id @default(cuid())
  stripeEventId    String    @unique
  stripeAccountId  String?
  type             String
  livemode         Boolean   @default(false)
  payloadJson      Json
  processingStatus String    @default("pending")
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  ledgerEntries LedgerEntry[]

  @@index([type, createdAt])
  @@index([stripeAccountId, createdAt])
  @@map("stripe_events")
}

model LedgerEntry {
  id                    String   @id @default(cuid())
  sellerId              String?
  sellerStripeAccountId String?
  orderId               String?
  stripeEventId         String?
  payoutRunId           String?
  stripeAccountId       String?
  entryType             String
  stripeObjectId        String?
  amount                Int
  currencyCode          String   @default("jpy")
  direction             String
  description           String?
  metadataJson          Json?
  occurredAt            DateTime
  createdAt             DateTime @default(now())

  seller              Seller?              @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  sellerStripeAccount SellerStripeAccount? @relation(fields: [sellerStripeAccountId], references: [id], onDelete: SetNull)
  order               Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  stripeEvent         StripeEvent?         @relation(fields: [stripeEventId], references: [id], onDelete: SetNull)
  payoutRun           PayoutRun?           @relation(fields: [payoutRunId], references: [id], onDelete: SetNull)

  @@index([sellerId, occurredAt])
  @@index([orderId, occurredAt])
  @@index([stripeAccountId, occurredAt])
  @@map("ledger_entries")
}

model SellerComplianceProfile {
  id                        String    @id @default(cuid())
  sellerId                  String    @unique
  entityType                String    @default("UNSET")
  legalName                 String?
  representativeName        String?
  postalCode                String?
  countryCode               String?
  region                    String?
  city                      String?
  address1                  String?
  address2                  String?
  phone                     String?
  invoiceRegistrationNumber String?
  permitsJson               Json?
  antisocialDeclarationAt   DateTime?
  shipFromConfirmedAt       DateTime?
  privacyNoticeAcceptedAt   DateTime?
  reviewStatus              String    @default("DRAFT")
  reviewedAt                DateTime?
  reviewedBy                String?
  reviewNotes               String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([reviewStatus, updatedAt])
  @@map("seller_compliance_profiles")
}

model SellerAgreementAcceptance {
  id               String    @id @default(cuid())
  acceptanceKey    String    @unique
  sellerId         String
  agreementType    String    @default("SELLER_MASTER")
  version          String
  documentHash     String
  acceptedBy       String
  acceptedByUserId String?
  acceptedByEmail  String?
  acceptedAt       DateTime  @default(now())
  source           String    @default("ADMIN_RECORDED")
  ipHash           String?
  userAgentHash    String?
  evidenceUrl      String?
  evidenceHash     String?
  revokedAt        DateTime?
  revokedBy        String?
  revocationReason String?
  metadataJson     Json?
  createdAt        DateTime  @default(now())

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([sellerId, agreementType, version, acceptedAt])
  @@index([agreementType, version, acceptedAt])
  @@map("seller_agreement_acceptances")
}

model SellerSettlementControl {
  id                   String    @id @default(cuid())
  sellerId             String    @unique
  salesHold            Boolean   @default(false)
  payoutHold           Boolean   @default(false)
  holdReason           String?
  reserveAmount        Int       @default(0)
  futureSetoffEnabled  Boolean   @default(false)
  directInvoiceBalance Int       @default(0)
  reviewedAt           DateTime?
  reviewedBy           String?
  metadataJson         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([payoutHold, salesHold, updatedAt])
  @@map("seller_settlement_controls")
}

model ProductComplianceProfile {
  id                      String    @id @default(cuid())
  productId               String    @unique
  legalSellerType         String    @default("VENDOR")
  conditionStatus         String    @default("UNSET")
  countryOfOriginCode     String?
  hsCode                  String?
  customsDescriptionEn    String?
  regulatoryCategory      String?
  regulatoryMarksJson     Json?
  ageRestriction          String?
  authenticityConfirmedAt DateTime?
  ipRightsConfirmedAt     DateTime?
  approvalStatus          String    @default("DRAFT")
  reviewedAt              DateTime?
  reviewedBy              String?
  reviewNotes             String?
  metadataJson            Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([approvalStatus, updatedAt])
  @@index([countryOfOriginCode, hsCode])
  @@map("product_compliance_profiles")
}

model MarketplaceOperationalCase {
  id                             String    @id @default(cuid())
  caseNumber                     String    @unique
  caseType                       String
  status                         String    @default("OPEN")
  priority                       String    @default("NORMAL")
  marketplaceOrderId             String?
  sellerOrderId                  String?
  sellerId                       String?
  responsibilitySellerId         String?
  vendorStoreId                  String?
  productId                      String?
  currencyCode                   String    @default("jpy")
  claimedAmount                  Int       @default(0)
  confirmedSellerLiabilityAmount Int       @default(0)
  platformLiabilityAmount        Int       @default(0)
  responsibilityStatus           String    @default("UNDETERMINED")
  summary                        String
  detailsJson                    Json?
  evidenceJson                   Json?
  resolutionType                 String?
  resolutionNotes                String?
  decisionReasonCode             String?
  responsibilityConfirmedAt      DateTime?
  responsibilityConfirmedBy      String?
  dueAt                          DateTime?
