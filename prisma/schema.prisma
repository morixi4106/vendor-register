generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model VendorStore {
  id         String   @id @default(cuid())
  ownerName  String
  storeName  String
  email      String
  phone      String
  address    String
  country    String
  category   String
  note       String?
  ageCheck   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendorAuth Vendor?
  seller     Seller?
  products   Product[]
}

model Product {
  id               String      @id @default(cuid())
  name             String
  description      String?
  imageUrl         String?
  category         String?
  price            Int
  costAmount       Decimal?    @db.Decimal(12, 2)
  costCurrency     String      @default("JPY")
  url              String?
  vendorStoreId    String
  approvalStatus   String      @default("pending")
  shopifyProductId String?
  shopDomain       String?
  calculatedPrice  Int?
  usedFxRate       Float?
  usedMargin       Float?
  usedDutyRate     Float?
  usedFee          Json?
  roundingResult   Json?
  calculatedAt     DateTime?
  priceSyncStatus  String      @default("calculated_not_applied")
  priceSyncError   String?
  priceAppliedAt   DateTime?
  lastPriceApplyAttemptAt DateTime?
  priceFormulaVersion String?
  priceSnapshotJson Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  vendorStore      VendorStore @relation(fields: [vendorStoreId], references: [id])
  priceApplyLogs   ProductPriceApplyLog[]

  @@unique([shopDomain, shopifyProductId])
  @@index([shopifyProductId])
}

model ProductPriceApplyLog {
  id                  String    @id @default(cuid())
  productId           String?
  shopifyProductId    String?
  shopDomain          String?
  attemptedPrice      Int?
  priceFormulaVersion String?
  status              String
  errorSummary        String?
  priceSnapshotJson   Json?
  attemptedAt         DateTime  @default(now())

  product             Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId, attemptedAt])
  @@index([shopifyProductId, shopDomain, attemptedAt])
}

model Vendor {
  id              String   @id @default(cuid())
  vendorStoreId   String   @unique
  storeName       String
  handle          String   @unique
  managementEmail String
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendorStore   VendorStore          @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  seller        Seller?
  loginCodes    VendorLoginCode[]
  adminSessions VendorAdminSession[]
}

model Seller {
  id                String                @id @default(cuid())
  vendorId          String                @unique
  vendorStoreId     String                @unique
  status            String                @default("pending")
  statusReason      String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  vendor            Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorStore       VendorStore           @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  stripeAccount     SellerStripeAccount?
  statusHistory     SellerStatusHistory[]
  orders            Order[]
  ledgerEntries     LedgerEntry[]
  payoutRuns        PayoutRun[]

  @@index([status, createdAt])
  @@map("sellers")
}

model SellerStripeAccount {
  id                   String        @id @default(cuid())
  sellerId             String        @unique
  stripeAccountId      String        @unique
  countryCode          String?
  defaultCurrency      String?
  detailsSubmitted     Boolean       @default(false)
  chargesEnabled       Boolean       @default(false)
  payoutsEnabled       Boolean       @default(false)
  payoutSchedule       String        @default("manual")
  dashboardType        String        @default("none")
  onboardingCompletedAt DateTime?
  requirementsJson     Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  seller               Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders               Order[]
  ledgerEntries        LedgerEntry[]
  payoutRuns           PayoutRun[]

  @@map("seller_stripe_accounts")
}

model SellerStatusHistory {
  id          String    @id @default(cuid())
  sellerId    String
  fromStatus  String?
  toStatus    String
  changedBy   String?
  reason      String?
  createdAt   DateTime  @default(now())

  seller      Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@map("seller_status_history")
}

model Order {
  id                   String               @id @default(cuid())
  sellerId             String
  sellerStripeAccountId String?
  stripeAccountId      String?
  status               String               @default("draft")
  currencyCode         String               @default("jpy")
  subtotalAmount       Int
  applicationFeeAmount Int
  totalAmount          Int
  customerEmail        String
  customerFirstName    String?
  customerLastName     String?
  customerPhone        String?
  shippingAddressJson  Json?
  lineItemsJson        Json
  stripePaymentIntentId String?            @unique
  stripeChargeId       String?             @unique
  paidAt               DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  seller               Seller              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerStripeAccount  SellerStripeAccount? @relation(fields: [sellerStripeAccountId], references: [id], onDelete: SetNull)
  ledgerEntries        LedgerEntry[]

  @@index([sellerId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model StripeEvent {
  id               String       @id @default(cuid())
  stripeEventId    String       @unique
  stripeAccountId  String?
  type             String
  livemode         Boolean      @default(false)
  payloadJson      Json
  processingStatus String       @default("pending")
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime     @default(now())

  ledgerEntries    LedgerEntry[]

  @@index([type, createdAt])
  @@index([stripeAccountId, createdAt])
  @@map("stripe_events")
}

model LedgerEntry {
  id                   String              @id @default(cuid())
  sellerId             String?
  sellerStripeAccountId String?
  orderId              String?
  stripeEventId        String?
  payoutRunId          String?
  stripeAccountId      String?
  entryType            String
  stripeObjectId       String?
  amount               Int
  currencyCode         String              @default("jpy")
  direction            String
  description          String?
  metadataJson         Json?
  occurredAt           DateTime
  createdAt            DateTime            @default(now())

  seller               Seller?             @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  sellerStripeAccount  SellerStripeAccount? @relation(fields: [sellerStripeAccountId], references: [id], onDelete: SetNull)
  order                Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  stripeEvent          StripeEvent?        @relation(fields: [stripeEventId], references: [id], onDelete: SetNull)
  payoutRun            PayoutRun?          @relation(fields: [payoutRunId], references: [id], onDelete: SetNull)

  @@index([sellerId, occurredAt])
  @@index([orderId, occurredAt])
  @@index([stripeAccountId, occurredAt])
  @@map("ledger_entries")
}

model PayoutRun {
  id                   String               @id @default(cuid())
  sellerId             String
  sellerStripeAccountId String
  stripeAccountId      String
  amount               Int
  currencyCode         String               @default("jpy")
  status               String               @default("draft")
  stripePayoutId       String?              @unique
  approvedAt           DateTime?
  approvedBy           String?
  executedAt           DateTime?
  executedBy           String?
  failureCode          String?
  failureMessage       String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  seller               Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerStripeAccount  SellerStripeAccount  @relation(fields: [sellerStripeAccountId], references: [id], onDelete: Cascade)
  ledgerEntries        LedgerEntry[]

  @@index([sellerId, createdAt])
  @@index([status, createdAt])
  @@map("payout_runs")
}

model VendorLoginCode {
  id         String   @id @default(cuid())
  vendorId   String
  email      String
  code       String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model VendorAdminSession {
  id           String   @id @default(cuid())
  vendorId     String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([expiresAt])
}

model ContactInquiry {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  message       String
  replyText     String
  replyType     String
  matchedRuleId String?
  createdAt     DateTime @default(now())
}

model FixedReplyCandidate {
  id        String   @id @default(cuid())
  message   String
  replyText String
  createdAt DateTime @default(now())
}

model FixedReplyRule {
  id         String   @id @default(cuid())
  keyword    String
  replyText  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FxRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([base, quote])
}
