generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model VendorStore {
  id         String   @id @default(cuid())
  ownerName  String
  storeName  String
  email      String
  phone      String
  address    String
  country    String
  category   String
  note       String?
  ageCheck   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendorAuth Vendor?
  products   Product[]
}

model Product {
  id               String      @id @default(cuid())
  name             String
  description      String?
  imageUrl         String?
  category         String?
  price            Int
  costAmount       Decimal?    @db.Decimal(12, 2)
  costCurrency     String      @default("JPY")
  url              String?
  vendorStoreId    String
  approvalStatus   String      @default("pending")
  shopifyProductId String?
  shopDomain       String?
  calculatedPrice  Int?
  usedFxRate       Float?
  usedMargin       Float?
  usedDutyRate     Float?
  usedFee          Json?
  roundingResult   Json?
  calculatedAt     DateTime?
  priceSyncStatus  String      @default("calculated_not_applied")
  priceSyncError   String?
  priceAppliedAt   DateTime?
  lastPriceApplyAttemptAt DateTime?
  priceFormulaVersion String?
  priceSnapshotJson Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  vendorStore      VendorStore @relation(fields: [vendorStoreId], references: [id])
  priceApplyLogs   ProductPriceApplyLog[]

  @@unique([shopDomain, shopifyProductId])
  @@index([shopifyProductId])
}

model ProductPriceApplyLog {
  id                  String    @id @default(cuid())
  productId           String?
  shopifyProductId    String?
  shopDomain          String?
  attemptedPrice      Int?
  priceFormulaVersion String?
  status              String
  errorSummary        String?
  priceSnapshotJson   Json?
  attemptedAt         DateTime  @default(now())

  product             Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId, attemptedAt])
  @@index([shopifyProductId, shopDomain, attemptedAt])
}

model Vendor {
  id              String   @id @default(cuid())
  vendorStoreId   String   @unique
  storeName       String
  handle          String   @unique
  managementEmail String
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendorStore   VendorStore          @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  loginCodes    VendorLoginCode[]
  adminSessions VendorAdminSession[]
}

model VendorLoginCode {
  id         String   @id @default(cuid())
  vendorId   String
  email      String
  code       String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model VendorAdminSession {
  id           String   @id @default(cuid())
  vendorId     String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([expiresAt])
}

model ContactInquiry {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  message       String
  replyText     String
  replyType     String
  matchedRuleId String?
  createdAt     DateTime @default(now())
}

model FixedReplyCandidate {
  id        String   @id @default(cuid())
  message   String
  replyText String
  createdAt DateTime @default(now())
}

model FixedReplyRule {
  id         String   @id @default(cuid())
  keyword    String
  replyText  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FxRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([base, quote])
}
