  requestedLineId    String
  instructedQuantity Int      @default(0)
  submittedQuantity  Int      @default(0)
  receivedQuantity   Int      @default(0)
  missingQuantity    Int      @default(0)
  conditionStatus    String   @default("UNDECIDED")
  conditionNotes     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  returnGroup   WithdrawalReturnGroup          @relation(fields: [returnGroupId], references: [id], onDelete: Restrict)
  requestedLine WithdrawalRequestedLine        @relation(fields: [requestedLineId], references: [id], onDelete: Restrict)
  shipmentLines WithdrawalReturnShipmentLine[]

  @@unique([returnGroupId, requestedLineId])
  @@index([requestedLineId])
  @@map("withdrawal_return_group_lines")
}

model WithdrawalReturnInstruction {
  id                      String    @id @default(cuid())
  returnGroupId           String
  version                 Int
  status                  String    @default("DRAFT")
  storeSnapshotJson       Json
  addressSnapshotJson     Json
  itemsSnapshotJson       Json
  deadlineSnapshotJson    Json
  returnCostSnapshotJson  Json
  notesSnapshot           String?
  templateVersion         String
  sentAt                  DateTime?
  sentBy                  String?
  supersedesInstructionId String?
  createdAt               DateTime  @default(now())

  returnGroup           WithdrawalReturnGroup         @relation(fields: [returnGroupId], references: [id], onDelete: Restrict)
  supersedesInstruction WithdrawalReturnInstruction?  @relation("WithdrawalInstructionSupersession", fields: [supersedesInstructionId], references: [id], onDelete: SetNull)
  supersededBy          WithdrawalReturnInstruction[] @relation("WithdrawalInstructionSupersession")
  emailLogs             WithdrawalEmailLog[]

  @@unique([returnGroupId, version])
  @@index([returnGroupId, status])
  @@map("withdrawal_return_instructions")
}

model WithdrawalReturnShipment {
  id                 String    @id @default(cuid())
  returnGroupId      String
  packageNumber      Int
  trackingCompany    String?
  trackingNumber     String?
  trackingUrl        String?
  customerMemo       String?
  proofJson          Json?
  submittedAt        DateTime?
  evidenceAcceptedAt DateTime?
  evidenceAcceptedBy String?
  receivedAt         DateTime?
  receivedBy         String?
  status             String    @default("SUBMITTED")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  returnGroup WithdrawalReturnGroup          @relation(fields: [returnGroupId], references: [id], onDelete: Restrict)
  lines       WithdrawalReturnShipmentLine[]

  @@unique([returnGroupId, packageNumber])
  @@index([trackingNumber])
  @@index([returnGroupId, status])
  @@map("withdrawal_return_shipments")
}

model WithdrawalReturnShipmentLine {
  id                String   @id @default(cuid())
  shipmentId        String
  returnGroupLineId String
  submittedQuantity Int      @default(0)
  receivedQuantity  Int      @default(0)
  missingQuantity   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shipment        WithdrawalReturnShipment  @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  returnGroupLine WithdrawalReturnGroupLine @relation(fields: [returnGroupLineId], references: [id], onDelete: Restrict)

  @@unique([shipmentId, returnGroupLineId])
  @@index([returnGroupLineId])
  @@map("withdrawal_return_shipment_lines")
}

model WithdrawalAccessToken {
  id            String    @id @default(cuid())
  returnGroupId String
  purpose       String
  tokenHash     String    @unique
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  firstUsedAt   DateTime?
  lastUsedAt    DateTime?
  issuedReason  String?
  revokedReason String?
  createdAt     DateTime  @default(now())

  returnGroup WithdrawalReturnGroup @relation(fields: [returnGroupId], references: [id], onDelete: Restrict)

  @@index([returnGroupId, purpose, expiresAt])
  @@map("withdrawal_access_tokens")
}

model WithdrawalActualRefundEvent {
  id                         String    @id @default(cuid())
  withdrawalRequestId        String
  shopDomain                 String
  shopifyRefundId            String
  shopifyOrderId             String?
  itemAmount                 Int       @default(0)
  initialShippingAmount      Int       @default(0)
  otherAmount                Int       @default(0)
  currencyCode               String    @default("JPY")
  webhookReceivedAt          DateTime?
  ledgerReconciliationStatus String    @default("PENDING")
  ledgerAmount               Int?
  reconciliationJson         Json?
  metadataJson               Json?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  withdrawalRequest WithdrawalRequest                  @relation(fields: [withdrawalRequestId], references: [id], onDelete: Restrict)
  allocations       WithdrawalActualRefundAllocation[]

  @@unique([withdrawalRequestId, shopDomain, shopifyRefundId])
  @@index([withdrawalRequestId, createdAt])
  @@map("withdrawal_actual_refund_events")
}

model WithdrawalActualRefundAllocation {
  id                    String   @id @default(cuid())
  actualRefundEventId   String
  withdrawalContractId  String?
  requestedLineId       String?
  shopifyLineItemId     String?
  quantity              Int      @default(0)
  itemAmount            Int      @default(0)
  initialShippingAmount Int      @default(0)
  createdAt             DateTime @default(now())

  actualRefundEvent  WithdrawalActualRefundEvent @relation(fields: [actualRefundEventId], references: [id], onDelete: Restrict)
  withdrawalContract WithdrawalContract?         @relation(fields: [withdrawalContractId], references: [id], onDelete: SetNull)
  requestedLine      WithdrawalRequestedLine?    @relation(fields: [requestedLineId], references: [id], onDelete: SetNull)

  @@index([actualRefundEventId])
  @@index([withdrawalContractId])
  @@index([requestedLineId])
  @@map("withdrawal_actual_refund_allocations")
}

model WiseTransferEvent {
  id               String    @id @default(cuid())
  wiseEventId      String    @unique
  wiseTransferId   String?
  payoutRunId      String?
  eventType        String
  payloadJson      Json
  processingStatus String    @default("pending")
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  payoutRun PayoutRun? @relation(fields: [payoutRunId], references: [id], onDelete: SetNull)

  @@index([wiseTransferId, createdAt])
  @@index([payoutRunId, createdAt])
  @@map("wise_transfer_events")
}

model VendorLoginCode {
  id        String    @id @default(cuid())
  vendorId  String
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model VendorAdminSession {
  id           String   @id @default(cuid())
  vendorId     String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([expiresAt])
}

model ContactInquiry {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  message       String
  replyText     String
  replyType     String
  matchedRuleId String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model PublicEndpointRateLimit {
  id          String   @id @default(cuid())
  endpoint    String
  keyHash     String
  windowStart DateTime
  count       Int      @default(0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([endpoint, keyHash, windowStart])
  @@index([endpoint, expiresAt])
  @@map("public_endpoint_rate_limits")
}

model FixedReplyCandidate {
  id        String   @id @default(cuid())
  message   String
  replyText String
  createdAt DateTime @default(now())
}

model FixedReplyRule {
  id        String   @id @default(cuid())
  keyword   String
  replyText String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FxRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([base, quote])
}
