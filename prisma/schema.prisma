generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model VendorStore {
  id          String   @id @default(cuid())
  ownerName   String
  storeName   String
  email       String
  phone       String
  address     String
  country     String
  category    String
  note        String?
  ageCheck    String
  isTestStore Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendorAuth Vendor?
  seller     Seller?
  products   Product[]
}

model Product {
  id                              String    @id @default(cuid())
  name                            String
  description                     String?
  imageUrl                        String?
  category                        String?
  price                           Int
  costAmount                      Decimal?  @db.Decimal(12, 2)
  costCurrency                    String    @default("JPY")
  url                             String?
  vendorStoreId                   String
  approvalStatus                  String    @default("pending")
  shopifyProductId                String?
  shopifyVariantId                String?
  shopDomain                      String?
  calculatedPrice                 Int?
  usedFxRate                      Float?
  usedMargin                      Float?
  usedDutyRate                    Float?
  usedFee                         Json?
  roundingResult                  Json?
  calculatedAt                    DateTime?
  priceSyncStatus                 String    @default("calculated_not_applied")
  priceSyncError                  String?
  priceAppliedAt                  DateTime?
  lastPriceApplyAttemptAt         DateTime?
  priceFormulaVersion             String?
  priceSnapshotJson               Json?
  inventoryQuantity               Int?
  inventorySyncedAt               DateTime?
  inventorySyncError              String?
  productEuStatus                 String    @default("DISABLED")
  euSaleRequested                 Boolean   @default(false)
  regulatorySelfCertificationJson Json?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  vendorStore    VendorStore            @relation(fields: [vendorStoreId], references: [id])
  priceApplyLogs ProductPriceApplyLog[]
  countryPolicy  ProductCountryPolicy?

  @@unique([shopDomain, shopifyProductId])
  @@unique([shopDomain, shopifyVariantId])
  @@index([shopifyProductId])
  @@index([shopifyVariantId])
  @@index([productEuStatus, updatedAt])
}

model ProductPriceApplyLog {
  id                  String   @id @default(cuid())
  productId           String?
  shopifyProductId    String?
  shopDomain          String?
  attemptedPrice      Int?
  priceFormulaVersion String?
  status              String
  errorSummary        String?
  priceSnapshotJson   Json?
  attemptedAt         DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId, attemptedAt])
  @@index([shopifyProductId, shopDomain, attemptedAt])
}

model Vendor {
  id              String   @id @default(cuid())
  vendorStoreId   String   @unique
  storeName       String
  handle          String   @unique
  managementEmail String
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendorStore   VendorStore          @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  seller        Seller?
  loginCodes    VendorLoginCode[]
  adminSessions VendorAdminSession[]
}

model Seller {
  id                         String    @id @default(cuid())
  vendorId                   String    @unique
  vendorStoreId              String    @unique
  status                     String    @default("pending")
  statusReason               String?
  sellerLegalRole            String    @default("MARKETPLACE_SELLER")
  sellerVerificationStatus   String    @default("NONE")
  euSellerStatus             String    @default("DISABLED")
  phoneVerifiedAt            DateTime?
  documentVerificationStatus String    @default("NONE")
  documentVerifiedAt         DateTime?
  documentVerifiedBy         String?
  verificationNameMatched    Boolean   @default(false)
  payoutNameMatched          Boolean   @default(false)
  verificationReviewNotes    String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  vendor              Vendor                     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorStore         VendorStore                @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  stripeAccount       SellerStripeAccount?
  payoutRecipient     SellerPayoutRecipient?
  statusHistory       SellerStatusHistory[]
  verificationRecords SellerVerificationRecord[]
  orders              Order[]
  ledgerEntries       LedgerEntry[]
  payoutRuns          PayoutRun[]
  salesCreditOffsets  SalesCreditOffset[]

  @@index([status, createdAt])
  @@index([sellerVerificationStatus, updatedAt])
  @@index([euSellerStatus, updatedAt])
  @@map("sellers")
}

model MarketplaceOrder {
  id                 String    @id @default(cuid())
  shopDomain         String
  shopifyOrderId     String
  shopifyOrderName   String?
  shopifyOrderNumber String?
  buyerEmail         String?
  buyerName          String?
  totalAmount        Int       @default(0)
  subtotalAmount     Int       @default(0)
  shippingAmount     Int       @default(0)
  discountAmount     Int       @default(0)
  taxAmount          Int       @default(0)
  currencyCode       String    @default("jpy")
  financialStatus    String?
  fulfillmentStatus  String?
  processedAt        DateTime?
  cancelledAt        DateTime?
  metadataJson       Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sellerOrders SellerOrder[]
  shadowChecks SellerOrderShadowCheck[]

  @@unique([shopDomain, shopifyOrderId])
  @@index([shopifyOrderId])
  @@index([shopDomain, createdAt])
  @@map("marketplace_orders")
}

model SellerOrder {
  id                       String   @id @default(cuid())
  marketplaceOrderId       String
  shopifyOrderId           String
  shopifyOrderName         String?
  sellerId                 String
  vendorStoreId            String?
  sellerSubtotalAmount     Int      @default(0)
  sellerDiscountAmount     Int      @default(0)
  sellerRefundAmount       Int      @default(0)
  sellerNetAmount          Int      @default(0)
  sellerPayableAmount      Int      @default(0)
  shippingQuotedAmount     Int      @default(0)
  shippingChargedAmount    Int      @default(0)
  shippingAllocationMethod String   @default("not_allocated")
  currencyCode             String   @default("jpy")
  paymentStatus            String   @default("paid")
  fulfillmentStatus        String   @default("unfulfilled")
  settlementStatus         String   @default("shadow")
  riskStatus               String   @default("normal")
  metadataJson             Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  marketplaceOrder MarketplaceOrder  @relation(fields: [marketplaceOrderId], references: [id], onDelete: Cascade)
  lines            SellerOrderLine[]
  shipments        SellerShipment[]

  @@unique([marketplaceOrderId, sellerId])
  @@index([sellerId, createdAt])
  @@index([vendorStoreId, createdAt])
  @@index([marketplaceOrderId])
  @@map("seller_orders")
}

model SellerOrderLine {
  id                 String   @id @default(cuid())
  sellerOrderId      String
  shopifyLineItemId  String
  shopifyProductId   String?
  shopifyVariantId   String?
  productId          String?
  title              String?
  sku                String?
  quantity           Int      @default(0)
  fulfilledQuantity  Int      @default(0)
  refundedQuantity   Int      @default(0)
  unitAmount         Int      @default(0)
  lineSubtotalAmount Int      @default(0)
  discountAmount     Int      @default(0)
  taxAmount          Int      @default(0)
  netAmount          Int      @default(0)
  currencyCode       String   @default("jpy")
  metadataJson       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sellerOrder   SellerOrder          @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  shipmentLines SellerShipmentLine[]

  @@unique([sellerOrderId, shopifyLineItemId])
  @@index([shopifyLineItemId])
  @@index([productId])
  @@map("seller_order_lines")
}

model SellerShipment {
  id                   String    @id @default(cuid())
  sellerOrderId        String
  shopifyFulfillmentId String?
  trackingNumber       String?
  trackingCompany      String?
  trackingUrl          String?
  status               String    @default("registered")
  shippedAt            DateTime?
  metadataJson         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  sellerOrder SellerOrder          @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  lines       SellerShipmentLine[]

  @@index([sellerOrderId, createdAt])
  @@index([shopifyFulfillmentId])
  @@index([trackingNumber])
  @@map("seller_shipments")
}

model SellerShipmentLine {
  id                                String   @id @default(cuid())
  sellerShipmentId                  String
  sellerOrderLineId                 String
  shopifyLineItemId                 String?
  shopifyFulfillmentOrderId         String
  shopifyFulfillmentOrderLineItemId String
  quantity                          Int      @default(0)
  createdAt                         DateTime @default(now())

  sellerShipment  SellerShipment  @relation(fields: [sellerShipmentId], references: [id], onDelete: Cascade)
  sellerOrderLine SellerOrderLine @relation(fields: [sellerOrderLineId], references: [id], onDelete: Cascade)

  @@unique([sellerShipmentId, shopifyFulfillmentOrderLineItemId])
  @@index([sellerOrderLineId])
  @@index([shopifyLineItemId])
  @@index([shopifyFulfillmentOrderId])
  @@map("seller_shipment_lines")
}

model SellerOrderShadowCheck {
  id                          String   @id @default(cuid())
  marketplaceOrderId          String?
  shopDomain                  String
  shopifyOrderId              String
  shopifyOrderName            String?
  status                      String
  currencyCode                String   @default("jpy")
  legacyLedgerAmount          Int?
  sellerOrderCalculatedAmount Int?
  legacySellerIdsJson         Json?
  sellerOrderSellerIdsJson    Json?
  differencesJson             Json?
  errorMessage                String?
  checkedAt                   DateTime @default(now())
  createdAt                   DateTime @default(now())

  marketplaceOrder MarketplaceOrder? @relation(fields: [marketplaceOrderId], references: [id], onDelete: SetNull)

  @@index([status, checkedAt])
  @@index([shopifyOrderId])
  @@index([marketplaceOrderId])
  @@map("seller_order_shadow_checks")
}

model SalesCreditOffset {
  id                String    @id @default(cuid())
  sellerId          String
  amount            Int
  currencyCode      String    @default("jpy")
  status            String    @default("authorized")
  checkoutReference String?
  idempotencyKey    String?   @unique
  expiresAt         DateTime?
  capturedAt        DateTime?
  releasedAt        DateTime?
  releaseReason     String?
  metadataJson      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, status, expiresAt])
  @@index([checkoutReference])
  @@map("sales_credit_offsets")
}

model SellerVerificationRecord {
  id                 String    @id @default(cuid())
  sellerId           String
  status             String
  verifiedAt         DateTime?
  verifiedBy         String?
  verificationMethod String?
  documentType       String?
  documentCountry    String?
  documentLast4      String?
  nameMatched        Boolean   @default(false)
  payoutNameMatched  Boolean   @default(false)
  phoneVerifiedAt    DateTime?
  rejectionReason    String?
  reviewNotes        String?
  createdAt          DateTime  @default(now())

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@index([status, createdAt])
  @@map("seller_verification_records")
}

model SellerStripeAccount {
  id                    String    @id @default(cuid())
  sellerId              String    @unique
  stripeAccountId       String    @unique
  countryCode           String?
  defaultCurrency       String?
  detailsSubmitted      Boolean   @default(false)
  chargesEnabled        Boolean   @default(false)
  payoutsEnabled        Boolean   @default(false)
  payoutSchedule        String    @default("manual")
  dashboardType         String    @default("none")
  onboardingCompletedAt DateTime?
  requirementsJson      Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders        Order[]
  ledgerEntries LedgerEntry[]
  payoutRuns    PayoutRun[]

  @@map("seller_stripe_accounts")
}

model SellerPayoutRecipient {
  id                   String    @id @default(cuid())
  sellerId             String    @unique
  provider             String    @default("wise")
  status               String    @default("pending")
  countryCode          String?
  currencyCode         String    @default("jpy")
  legalType            String?
  accountHolderName    String?
  wiseProfileId        String?
  wiseRecipientId      String?   @unique
  wiseRecipientHash    String?
  accountSummary       String?
  longAccountSummary   String?
  recipientPayloadJson Json?
  requirementsJson     Json?
  verificationJson     Json?
  lastSyncedAt         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  seller     Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  payoutRuns PayoutRun[]

  @@index([provider, status])
  @@index([wiseRecipientId])
  @@map("seller_payout_recipients")
}

model SellerStatusHistory {
  id         String   @id @default(cuid())
  sellerId   String
  fromStatus String?
  toStatus   String
  changedBy  String?
  reason     String?
  createdAt  DateTime @default(now())

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@map("seller_status_history")
}

model Order {
  id                    String    @id @default(cuid())
  sellerId              String
  sellerStripeAccountId String?
  stripeAccountId       String?
  status                String    @default("draft")
  currencyCode          String    @default("jpy")
  subtotalAmount        Int
  applicationFeeAmount  Int
  totalAmount           Int
  customerEmail         String
  customerFirstName     String?
  customerLastName      String?
  customerPhone         String?
  shippingAddressJson   Json?
  lineItemsJson         Json
  stripePaymentIntentId String?   @unique
  stripeChargeId        String?   @unique
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  seller              Seller               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerStripeAccount SellerStripeAccount? @relation(fields: [sellerStripeAccountId], references: [id], onDelete: SetNull)
  ledgerEntries       LedgerEntry[]

  @@index([sellerId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model StripeEvent {
  id               String    @id @default(cuid())
  stripeEventId    String    @unique
  stripeAccountId  String?
  type             String
  livemode         Boolean   @default(false)
  payloadJson      Json
  processingStatus String    @default("pending")
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  ledgerEntries LedgerEntry[]

  @@index([type, createdAt])
  @@index([stripeAccountId, createdAt])
  @@map("stripe_events")
}

model LedgerEntry {
  id                    String   @id @default(cuid())
  sellerId              String?
  sellerStripeAccountId String?
  orderId               String?
  stripeEventId         String?
  payoutRunId           String?
  stripeAccountId       String?
  entryType             String
  stripeObjectId        String?
  amount                Int
  currencyCode          String   @default("jpy")
  direction             String
  description           String?
  metadataJson          Json?
  occurredAt            DateTime
  createdAt             DateTime @default(now())

  seller              Seller?              @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  sellerStripeAccount SellerStripeAccount? @relation(fields: [sellerStripeAccountId], references: [id], onDelete: SetNull)
  order               Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  stripeEvent         StripeEvent?         @relation(fields: [stripeEventId], references: [id], onDelete: SetNull)
  payoutRun           PayoutRun?           @relation(fields: [payoutRunId], references: [id], onDelete: SetNull)

  @@index([sellerId, occurredAt])
  @@index([orderId, occurredAt])
  @@index([stripeAccountId, occurredAt])
  @@map("ledger_entries")
}

model PayoutRun {
  id                        String    @id @default(cuid())
  sellerId                  String
  sellerStripeAccountId     String?
  sellerPayoutRecipientId   String?
  stripeAccountId           String?
  amount                    Int
  currencyCode              String    @default("jpy")
  status                    String    @default("draft")
  transferMethod            String    @default("manual_bank_transfer")
  stripePayoutId            String?   @unique
  wiseQuoteId               String?
  wiseTransferId            String?   @unique
  wiseTransferStatus        String?
  wiseCustomerTransactionId String?   @unique
  wiseSourceCurrency        String?
  wiseTargetCurrency        String?
  wiseSourceAmount          Decimal?  @db.Decimal(18, 6)
  wiseTargetAmount          Decimal?  @db.Decimal(18, 6)
  wiseFeeAmount             Decimal?  @db.Decimal(18, 6)
  wiseRate                  Decimal?  @db.Decimal(18, 10)
  wiseFailureCode           String?
  wiseFailureMessage        String?
  wisePayloadJson           Json?
  externalTransferId        String?
  transferMemo              String?
  approvedAt                DateTime?
  approvedBy                String?
  executedAt                DateTime?
  executedBy                String?
  failureCode               String?
  failureMessage            String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  seller                Seller                 @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerStripeAccount   SellerStripeAccount?   @relation(fields: [sellerStripeAccountId], references: [id], onDelete: SetNull)
  sellerPayoutRecipient SellerPayoutRecipient? @relation(fields: [sellerPayoutRecipientId], references: [id], onDelete: SetNull)
  ledgerEntries         LedgerEntry[]
  wiseEvents            WiseTransferEvent[]

  @@index([sellerId, createdAt])
  @@index([status, createdAt])
  @@index([sellerPayoutRecipientId, createdAt])
  @@index([wiseTransferStatus, updatedAt])
  @@map("payout_runs")
}

model ProductCountryPolicy {
  id                       String   @id @default(cuid())
  productId                String   @unique
  allowedCountries         Json?
  blockedCountries         Json?
  requiresWarningCountries Json?
  euSaleStatus             String   @default("DISABLED")
  warningVersion           String   @default("import-responsibility-v1")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([euSaleStatus, updatedAt])
  @@map("product_country_policies")
}

model DeliveryCountryPolicyTemplate {
  id                       String   @id @default(cuid())
  name                     String   @unique
  categoryName             String?
  description              String?
  productEuStatus          String   @default("DISABLED")
  allowedCountries         Json?
  blockedCountries         Json?
  requiresWarningCountries Json?
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([isActive, name])
  @@map("delivery_country_policy_templates")
}

model BuyerWarningAcceptance {
  id                           String   @id @default(cuid())
  orderId                      String?
  buyerId                      String?
  selectedCountry              String?
  shippingCountry              String
  productIds                   Json
  warningVersion               String
  acceptedAt                   DateTime @default(now())
  ipAddress                    String?
  userAgent                    String?
  importResponsibilityAccepted Boolean  @default(false)
  metadataJson                 Json?
  createdAt                    DateTime @default(now())

  @@index([orderId])
  @@index([shippingCountry, acceptedAt])
  @@map("buyer_warning_acceptances")
}

model WithdrawalRequest {
  id                          String    @id @default(cuid())
  shopDomain                  String?
  marketplaceOrderId          String?
  shopifyOrderId              String?
  shopifyOrderName            String?
  shopifyOrderNumber          String?
  customerName                String
  customerEmail               String
  customerPhone               String?
  countryCode                 String?
  countryLabel                String?
  receivedDate                DateTime?
  withdrawalScope             String    @default("FULL")
  itemCondition               String?
  reason                      String?
  status                      String    @default("REQUESTED")
  eligibilityStatus           String    @default("PENDING_REVIEW")
  deadlineAt                  DateTime?
  deadlineSource              String?
  selectedLineItemsJson       Json?
  submittedPayloadJson        Json
  orderSnapshotJson           Json?
  eligibilityJson             Json?
  durableMediumEmailJson      Json?
  confirmationSentAt          DateTime?
  confirmationEmailMessageId  String?
  decisionSentAt              DateTime?
  returnRequirementStatus     String    @default("UNDECIDED")
  returnTrackingCompany       String?
  returnTrackingNumber        String?
  returnTrackingUrl           String?
  returnReceivedAt            DateTime?
  returnConditionStatus       String    @default("UNDECIDED")
  returnConditionNotes        String?
  returnProofJson             Json?
  returnInfoUpdatedAt         DateTime?
  returnInfoUpdatedBy         String?
  refundDecisionStatus        String    @default("UNDECIDED")
  refundItemAmount            Int?
  refundInitialShippingAmount Int?
  refundDeductionAmount       Int?
  refundTotalAmount           Int?
  refundCurrencyCode          String?
  returnShippingPayer         String?
  refundDecisionReason        String?
  refundDecisionNotes         String?
  refundDecisionUpdatedAt     DateTime?
  refundDecisionUpdatedBy     String?
  completedAt                 DateTime?
  rejectedAt                  DateTime?
  rejectionReason             String?
  adminNotes                  String?
  source                      String    @default("app_proxy")
  ipAddress                   String?
  userAgent                   String?
  idempotencyKey              String    @unique
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  statusHistory WithdrawalRequestStatusHistory[]
  emailLogs     WithdrawalEmailLog[]

  @@index([shopDomain, shopifyOrderId])
  @@index([shopDomain, shopifyOrderName])
  @@index([customerEmail, createdAt])
  @@index([status, createdAt])
  @@index([eligibilityStatus, createdAt])
  @@index([returnRequirementStatus, createdAt])
  @@index([refundDecisionStatus, createdAt])
  @@map("withdrawal_requests")
}

model WithdrawalRequestStatusHistory {
  id                  String   @id @default(cuid())
  withdrawalRequestId String
  fromStatus          String?
  toStatus            String
  changedBy           String?
  reason              String?
  metadataJson        Json?
  createdAt           DateTime @default(now())

  withdrawalRequest WithdrawalRequest @relation(fields: [withdrawalRequestId], references: [id], onDelete: Cascade)

  @@index([withdrawalRequestId, createdAt])
  @@index([toStatus, createdAt])
  @@map("withdrawal_request_status_history")
}

model WithdrawalEmailLog {
  id                  String    @id @default(cuid())
  withdrawalRequestId String
  emailType           String
  toEmail             String
  fromEmail           String?
  subject             String
  bodyText            String?
  bodyHtml            String?
  provider            String    @default("resend")
  providerMessageId   String?
  status              String    @default("sent")
  errorMessage        String?
  sentAt              DateTime?
  createdAt           DateTime  @default(now())

  withdrawalRequest WithdrawalRequest @relation(fields: [withdrawalRequestId], references: [id], onDelete: Cascade)

  @@index([withdrawalRequestId, createdAt])
  @@index([emailType, createdAt])
  @@map("withdrawal_email_logs")
}

model WiseTransferEvent {
  id               String    @id @default(cuid())
  wiseEventId      String    @unique
  wiseTransferId   String?
  payoutRunId      String?
  eventType        String
  payloadJson      Json
  processingStatus String    @default("pending")
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  payoutRun PayoutRun? @relation(fields: [payoutRunId], references: [id], onDelete: SetNull)

  @@index([wiseTransferId, createdAt])
  @@index([payoutRunId, createdAt])
  @@map("wise_transfer_events")
}

model VendorLoginCode {
  id        String    @id @default(cuid())
  vendorId  String
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model VendorAdminSession {
  id           String   @id @default(cuid())
  vendorId     String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([expiresAt])
}

model ContactInquiry {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  message       String
  replyText     String
  replyType     String
  matchedRuleId String?
  createdAt     DateTime @default(now())
}

model FixedReplyCandidate {
  id        String   @id @default(cuid())
  message   String
  replyText String
  createdAt DateTime @default(now())
}

model FixedReplyRule {
  id        String   @id @default(cuid())
  keyword   String
  replyText String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FxRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([base, quote])
}
