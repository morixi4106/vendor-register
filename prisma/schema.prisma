generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model VendorStore {
  id         String   @id @default(cuid())
  ownerName  String
  storeName  String
  email      String
  phone      String
  address    String
  country    String
  category   String
  note       String?
  ageCheck   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendorAuth Vendor?
  products   Product[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  price         Int
  url           String?
  vendorStoreId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendorStore   VendorStore @relation(fields: [vendorStoreId], references: [id])
}

model Vendor {
  id              String   @id @default(cuid())
  vendorStoreId   String   @unique
  storeName       String
  handle          String   @unique
  managementEmail String
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendorStore   VendorStore         @relation(fields: [vendorStoreId], references: [id], onDelete: Cascade)
  loginCodes    VendorLoginCode[]
  adminSessions VendorAdminSession[]
}

model VendorLoginCode {
  id         String   @id @default(cuid())
  vendorId   String
  email      String
  code       String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([code])
  @@index([expiresAt])
}

model VendorAdminSession {
  id           String   @id @default(cuid())
  vendorId     String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([expiresAt])
}